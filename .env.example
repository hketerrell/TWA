# Client-side direct upload (optional):
# If set, browser uploads directly to this full SAS URL.
VITE_BLOB_UPLOAD_SAS_URL=

# Server-side upload (recommended to keep token secret):
# Base blob URL WITHOUT query token, e.g.
# https://<account>.blob.core.windows.net/<container>/flight-data.json
BLOB_UPLOAD_URL=

# Read/write token (SAS token query string only, no leading '?').
# Keep this secret on the server; do NOT prefix with VITE_.
BLOB_READ_WRITE_TOKEN=
